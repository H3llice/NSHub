generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id           Int      @id @default(autoincrement())
  nome         String
  sigla        String   @unique
  endereco     String
  cidade       String
  cep          String
  cnpj         String
  inscEstadual String?
  telefone     String?
  email        String?
  criadoEm     DateTime @default(now())

  ordensCompra OrdemCompra[]
  solicitacoes SolicitacaoCompra[]
}

model Fornecedor {
  id           Int      @id @default(autoincrement())
  nome         String
  endereco     String?
  cidade       String?
  cep          String?
  documento    String?
  inscEstadual String?
  telefone     String?
  criadoEm     DateTime @default(now())

  ordensCompra OrdemCompra[]
  vendedores   Vendedor[]
}

model Vendedor {
  id           Int        @id @default(autoincrement())
  nome         String
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id])
  fornecedorId Int

  ordensCompra OrdemCompra[]
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  perfil    String   @default("usuario")
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())
  primeiroLogin    Boolean   @default(true)
  resetToken       String?
  resetTokenExpira DateTime?

  ordensCompra OrdemCompra[]
  assinaturas  Assinatura[]
  solicitacoes SolicitacaoCompra[]
}

// etapa: solicitante | aprovacao | autorizacao
// Cada assinatura pertence a UMA OrdemCompra OU UMA SolicitacaoCompra (nunca as duas)
model Assinatura {
  id            Int          @id @default(autoincrement())
  ordemCompra   OrdemCompra? @relation(fields: [ocId], references: [id])
  ocId          Int?
  solicitacao   SolicitacaoCompra? @relation(fields: [solicitacaoId], references: [id])
  solicitacaoId Int?
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])
  usuarioId     Int
  etapa         String
  acao          String
  motivo        String?
  assinaturaImg String?
  criadoEm      DateTime     @default(now())
}

model OrdemCompra {
  id             Int        @id @default(autoincrement())
  numero         Int
  ano            Int
  empresa        Empresa    @relation(fields: [empresaId], references: [id])
  empresaId      Int
  fornecedor     Fornecedor @relation(fields: [fornecedorId], references: [id])
  fornecedorId   Int
  vendedor       Vendedor?  @relation(fields: [vendedorId], references: [id])
  vendedorId     Int?
  criadoPor      Usuario?   @relation(fields: [criadoPorId], references: [id])
  criadoPorId    Int?
  dataPedido     DateTime   @default(now())
  condicoesPagto String?
  formaPagto     String?
  prazoEntrega   String?
  incoterms      String?
  transportadora String?
  enderecoTransp String?
  telefoneTransp String?
  instrucoes     String?
  solicitante    String?
  status         String     @default("aguardando_solicitante")
  criadoEm       DateTime   @default(now())
  atualizadoEm   DateTime   @updatedAt
  canceladoEm    DateTime?

  // Rastreabilidade interna — vínculo com a Solicitação que originou esta OC.
  // Não aparece na tela/PDF da OC, é só para consulta interna.
  geradaDeSolicitacaoId Int?                @unique
  geradaDeSolicitacao   SolicitacaoCompra?  @relation("OcGerada", fields: [geradaDeSolicitacaoId], references: [id])

  itens       ItemOC[]
  anexos      Anexo[]
  assinaturas Assinatura[]
}

model ItemOC {
  id          Int         @id @default(autoincrement())
  ordemCompra OrdemCompra @relation(fields: [ocId], references: [id])
  ocId        Int
  quantidade  Float
  unidade     String?
  descricao   String
  valorUni    Float?
  ipi         Float?
  valorTotal  Float?
}

model Anexo {
  id           Int         @id @default(autoincrement())
  ordemCompra  OrdemCompra @relation(fields: [ocId], references: [id])
  ocId         Int
  nomeOriginal String
  nomeArquivo  String
  tipo         String
  mimeType     String
  criadoEm     DateTime    @default(now())
}

// ════════════════════════════════════════════════════════════════════════════
// SOLICITAÇÃO DE COMPRA — cotação com múltiplos fornecedores concorrendo
// ════════════════════════════════════════════════════════════════════════════

model SolicitacaoCompra {
  id          Int      @id @default(autoincrement())
  numero      Int
  ano         Int
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  empresaId   Int
  criadoPor   Usuario? @relation(fields: [criadoPorId], references: [id])
  criadoPorId Int?
  dataPedido  DateTime @default(now())
  instrucoes  String?
  status      String   @default("aguardando_aprovacao")
  // status: aguardando_aprovacao | aprovada | recusada | cancelada

  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  canceladoEm  DateTime?

  itens        ItemSolicitacao[]
  fornecedores FornecedorCotado[]
  assinaturas  Assinatura[]

  // Vínculo inverso (1:1, opcional) com a OC gerada a partir desta solicitação
  ocGerada     OrdemCompra? @relation("OcGerada")
}

model ItemSolicitacao {
  id            Int               @id @default(autoincrement())
  solicitacao   SolicitacaoCompra @relation(fields: [solicitacaoId], references: [id])
  solicitacaoId Int
  quantidade    Float
  unidade       String?
  descricao     String

  precos        PrecoCotado[]
}

model FornecedorCotado {
  id             Int               @id @default(autoincrement())
  solicitacao    SolicitacaoCompra @relation(fields: [solicitacaoId], references: [id])
  solicitacaoId  Int
  nome           String
  documento      String?
  telefone       String?
  prazoEntrega   String?
  condicoesPagto String?
  observacoes    String?
  favorito       Boolean           @default(false)  // marcado pelo solicitante
  escolhido      Boolean           @default(false)  // marcado pelo gerente na aprovação

  precos         PrecoCotado[]
}

model PrecoCotado {
  id                 Int              @id @default(autoincrement())
  item               ItemSolicitacao  @relation(fields: [itemSolicitacaoId], references: [id])
  itemSolicitacaoId  Int
  fornecedor         FornecedorCotado @relation(fields: [fornecedorCotadoId], references: [id])
  fornecedorCotadoId Int
  valor              Float?           // null = não cotado por esse fornecedor

  @@unique([itemSolicitacaoId, fornecedorCotadoId])
}
